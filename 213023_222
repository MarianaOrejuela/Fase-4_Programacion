import tkinter as tk
from tkinter import ttk, messagebox
from abc import ABC, abstractmethod
from datetime import datetime
import sys, os, re

# Ruta donde se guardaran los eventos y errores del sistema.
LOG = os.path.join(os.path.dirname(os.path.abspath(__file__)), "logs.txt")

#Expresiones para validar los datos
ALFANUM = re.compile(r'^[A-Za-z0-9 \-]+$')   
ALFA    = re.compile(r'^[A-Za-z ]+$')     

MONEDA  = "COP"

def log(nivel, msg):
    """Guarda eventos/errores en logs.txt."""
    try:
        with open(LOG, "a", encoding="utf-8") as f:
            f.write(f"[{datetime.now():%Y-%m-%d %H:%M:%S}] [{nivel}] {msg}\n")
    except OSError:
        pass

def fmt(v):                                    
    return f"{MONEDA} ${v:,.0f}"

# Excepcion personalizada del sistema
class SoftwareFJError(Exception): pass         

class ErrorSistema(Exception):
    pass

class ErrorValidacion(ErrorSistema):
    pass

class ErrorReserva(ErrorSistema):
    pass

class ErrorServicio(ErrorSistema):
    pass

# CLASE ABSTRACTA GENERAL DEL SISTEMA
class Entidad(ABC):
    def __init__(self, codigo):
        self._codigo = codigo

    @property
    def codigo(self):
        return self._codigo

#------CLASE cliente-----

class Cliente(Entidad):
    _contador_id = 1       #contador de clase para generar IDs unicos

    def __init__(self, nombre, correo, telefono):
        self.__id = Cliente._contador_id          # ID autoincremental
        Cliente._contador_id += 1
        self.__nombre = None
        self.__correo = None
        self.__telefono = None

        # Se usan los setters para aplicar validaciones al crear el objeto
        self.nombre = nombre
        self.correo = correo
        self.telefono = telefono

  # propiedad: nombre
@property
    def nombre(self):
        return self.__nombre

    @nombre.setter
    def nombre(self, valor):
        if not valor or not valor.strip():
            raise ErrorCliente("Client name cannot be empty.")
        if len(valor.strip()) < 3:
            raise ErrorCliente("Client name must have at least 3 characters.")
        self.__nombre = valor.strip()


